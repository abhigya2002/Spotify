# Groq LLM (pulse generation)
GROQ_API_KEY=your_key_here
GROQ_MODEL=llama-3.3-70b-versatile
PULSE_TEMPERATURE=0.2
MAX_PULSE_WORDS=250

# MCP delivery (saksham-mcp-server on Railway)
MCP_SERVER_URL=https://saksham-mcp-server-production-4691.up.railway.app
GOOGLE_DOC_ID=your_google_doc_id_here
RECIPIENT_EMAIL=your-email@example.com
